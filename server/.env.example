# ══════════════════════════════════════════════════════════════════════════════
# Zaymazone Backend — Environment Variables Template  (Module 7)
# Copy this file to .env and fill in every value before starting the server.
# Lines marked REQUIRED will cause the server to refuse to start if missing.
# ══════════════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production           # development | production
PORT=4000                     # HTTP port the server listens on

# ── Database  [REQUIRED] ──────────────────────────────────────────────────────
# MongoDB Atlas connection string.  Replace <user>, <password>, <cluster>, <db>
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority

# ── Authentication  [REQUIRED] ────────────────────────────────────────────────
# Long random secret used to sign JWT tokens.  Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_strong_random_secret_min_32_chars

# ── Firebase  [REQUIRED] ──────────────────────────────────────────────────────
# Firebase project ID (visible in Firebase Console > Project settings)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Service account credentials for Firebase Admin SDK.
# Option A — JSON key file path (relative to server/ directory):
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# Option B — inline JSON (useful for hosting platforms that use env vars):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── Payments (Razorpay) ───────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ── Payments (UPI / Bharat Pe / custom) ──────────────────────────────────────
UPI_VPA=merchant@upi              # Merchant Virtual Payment Address
UPI_MERCHANT_ID=your_merchant_id
UPI_MERCHANT_NAME=Zaymazone

# ── Email (Nodemailer) ────────────────────────────────────────────────────────
EMAIL_USER=no-reply@zaymazone.com
EMAIL_PASS=your_email_app_password
EMAIL_FROM="Zaymazone <no-reply@zaymazone.com>"
# For Gmail: use an App Password, not your account password.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587

# ── Admin ─────────────────────────────────────────────────────────────────────
# Secret header/token for admin-only endpoints (e.g. POST /api/admin-approvals)
ADMIN_SECRET=replace_with_strong_admin_secret

# ── Database seeding  (Module 7 security gate) ────────────────────────────────
# Set this to a strong random value to allow POST /api/seed in production.
# Leave UNSET (or blank) to disable the endpoint entirely — recommended for live.
# SEED_SECRET=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of additional allowed origins (the hardcoded list in
# src/index.js is always included; add any extra deploy URLs here).
# EXTRA_ALLOWED_ORIGINS=https://my-custom-domain.com

# ── File storage ──────────────────────────────────────────────────────────────
# Uploads are stored in GridFS (MongoDB) by default.
# UPLOAD_MAX_SIZE_MB=20   # Default: 20
